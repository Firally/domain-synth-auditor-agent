# Скопируй этот файл в .env и заполни своими ключами
# cp .env.example .env

# OpenRouter API key (обязательно)
# Получить на: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# MySQL (опционально — нужно только для --source db)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=synth_auditor
